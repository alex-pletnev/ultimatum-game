<?xml version="1.0" encoding="UTF-8"?>
<!--
  Профили логирования:
    * dev  (default) — plaintext, читаемо в консоли
    * prod           — JSON в stdout (одно событие = одна строка)

  MDC-поля, включённые в pattern/JSON:
    traceId, spanId  — от Micrometer Tracing (bridge-brave)
    userId, role     — от JwtAuthenticationFilter / JwtStompChannelInterceptor
    sessionId, roundId — от игровых сервисов через MDC.putCloseable
-->
<configuration>

    <springProfile name="!prod">
        <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>
                    %d{HH:mm:ss.SSS} %-5level [%thread] [traceId=%X{traceId:-} userId=%X{userId:-} sessionId=%X{sessionId:-}] %logger{36} - %msg%n
                </pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="STDOUT"/>
        </root>
    </springProfile>

    <springProfile name="prod">
        <appender name="STDOUT_JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>spanId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <includeMdcKeyName>role</includeMdcKeyName>
                <includeMdcKeyName>sessionId</includeMdcKeyName>
                <includeMdcKeyName>roundId</includeMdcKeyName>
                <customFields>{"service":"ultimatum-game"}</customFields>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="STDOUT_JSON"/>
        </root>
    </springProfile>

</configuration>
